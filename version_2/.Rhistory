data(iris)
#ESCALAMIENTO MULTIDIMENSIONAL MDS: reduccion de variables
d = dist(iris[,1:4])
mds = cmdscale(d, k=2, eig =  TRUE)
x  = mds$points[,1]
y  = mds$points[,2]
plot(x,y,col=c("red","green","blue")[iris$Species])
#K-Means
gr = kmeans(iris[,1:4],3)
g1 = gr$size #Tamano grupos
g2 = gr$cluster #Cada instancia a que grupo pertenece
plot(x,y,col=c("red","green","blue")[g2])
#DHC
#install.packages("dendextend")
#library(dendextend)
h = hclust(d,method = "single") #Hizo el arbol
#Podacion: Para formar grupos
cl3 = cutree(h,3) #arbol y cuantos grupos quiero que haga o de 0 a 1 donde quiero que corte en ese valor
g3 = table(cl3) #Tamano de los grupos
h1 = hclust(d,method = "average") #Hizo el arbol
#Podacion: Para formar grupos
clu3 = cutree(h1,3) #arbol y cuantos grupos quiero que haga de 0 a 1 donde quiero que corte en ese valor
g31 = table(clu3) #Tamano de los grupos
g4 = clu3
#DENDOGRAMA
de = as.dendrogram(h1)
de = color_branches(de,3)
data(iris)
#ESCALAMIENTO MULTIDIMENSIONAL MDS: reduccion de variables
d = dist(iris[,1:4])
mds = cmdscale(d, k=2, eig =  TRUE)
x  = mds$points[,1]
y  = mds$points[,2]
plot(x,y,col=c("red","green","blue")[iris$Species])
#K-Means
gr = kmeans(iris[,1:4],3)
g1 = gr$size #Tamano grupos

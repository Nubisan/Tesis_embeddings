#DHC
install.packages("dendextend")
library(dendextend)
h = hclust(d,method = "single") #Hizo el arbol
#Podacion: Para formar grupos
cl3 = cutree(h,3) #arbol y cuantos grupos quiero que haga o de 0 a 1 donde quiero que corte en ese valor
g3 = table(cl3) #Tamano de los grupos
h1 = hclust(d,method = "average") #Hizo el arbol
#Podacion: Para formar grupos
clu3 = cutree(h1,3) #arbol y cuantos grupos quiero que haga de 0 a 1 donde quiero que corte en ese valor
g31 = table(clu3) #Tamano de los grupos
g4 = clu3
#DENDOGRAMA
de = as.dendrogram(h1)
de = color_branches(de,3)
col=c("red","green","blue")
plot(de,fill=col[g4])
#METODO DE ELBOW: me dice en cuantos grupos tendria que dividir para que me salga un mejor cluster
wi = c() #ERROR INTERNO EN CADA UNA DE LAS ITERACIONES
for (i in 1:10){
#K-Means
g = kmeans(iris[,1:4],i)
wi[i] = g$tot.withinss
}
plot((1:length(wi)),wi,type = "l")
#EVALUACION INTERNA DEL CLUSTER
#install.packages("clValid")
#install.packages("cluster")
library(clValid)
library(cluster)
du1 = dunn(d,g2) #Modelo KMeans
du2 = dunn(d,g4) #Modelo DHC
#COEFICIENTE DE SILUETA (DIAGRAMA)
si1 = silhouette(g2,d) #Modelo KMeans
plot(si1, col=c(1:3), border = NA)
si2 = silhouette(g4,d) #Modelo DHC
plot(si2, col=c(4:6), border = NA)
#PROCESO DE VALIDACION EXTERNA (ARI,AMI, NMI)
install.packages("aricode")
library(aricode)
v1 = c("gato", "gato", "perro", "iguana", "perro")
v2 = c(4,4,2,5,2)
#ARI: Es igual a 1 porque las etiquetas coinciden, estan en los mismos grupos 3 grupos
ARI(v1,v2)
v2 = c(4,4,2,2,5)
#Este ARI disminuye porque estan desordenadas las etiquetas
ground_truth = iris$Species
#ARI
ari1 = ARI(ground_truth, g2) #Kmeans
ari2 = ARI(ground_truth, g4) #DHC
#AMI
ami1 = AMI(ground_truth, g2)
ami2 = AMI(ground_truth, g4)
#NMI
nmi1 = NMI(ground_truth, g2, variant = "sqrt")
nmi2 = NMI(ground_truth, g4, variant = "sqrt")
si1
#CARGA DE DATOS
data("iris")
force(iris)
cant_datos = 100
train = 0.7
test = 1-train
iris[,5]= (iris$Species=="setosa")*1
#Division de datos
data_train = iris[(1:(cant_datos*train)),]
data_test = iris[((cant_datos*train+1):(cant_datos)),]
library(caret) #metodo de k-fold de forma automizada
ctrl = trainControl(method = "cv", number = 10) #ten-fold cross validation
modelo = train(as.factor(Species)~Sepal.Length+Sepal.Width+Petal.Length+Petal.Width, data = data_train,
trControl= ctrl, method = "glm", metric = "Accuracy")
#Ver con que modelo se ha quedado va hacer los reemplazos
#Con la libreria cart se eita armar el modelo
modelo$finalModel
View(modelo)
summary(modelo$finalModel)
#Predicciones en el Test
#Se le envia todo el modelo el escoge el mejor y las variables independientes
p = predict(modelo, newdata = data_test[,1:4])
p
data_test$Species
